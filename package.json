{
    "name": "@dpuse/dpuse-tool-rust-csv-core",
    "version": "0.1.21",
    "description": "CSV parser tool with Rust/WASM core for high-performance streaming",
    "license": "MIT",
    "private": false,
    "type": "module",
    "homepage": "https://www.dpuse.app",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/dpuse/dpuse-tool-rust-csv-core.git"
    },
    "bugs": {
        "url": "https://github.com/dpuse/dpuse-tool-rust-csv-core/issues"
    },
    "module": "./dist/dpuse-tool-rust-csv-core.es.js",
    "types": "./dist/types/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/dpuse-tool-rust-csv-core.es.js",
            "types": "./dist/types/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "prettier": "@dpuse/dpuse-development/prettierrc",
    "dependencies": {
        "@dpuse/dpuse-shared": "^0.3.642"
    },
    "devDependencies": {
        "@dpuse/dpuse-development": "^0.3.496",
        "@dpuse/eslint-config-dpuse": "^1.0.55",
        "@types/node": "^25.6.0",
        "@typescript-eslint/eslint-plugin": "^8.59.0",
        "@typescript-eslint/parser": "^8.59.0",
        "eslint": "^9.39.4",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-security": "^4.0.0",
        "eslint-plugin-sonarjs": "^4.0.3",
        "eslint-plugin-unicorn": "^63.0.0",
        "jiti": "^2.6.1",
        "license-downloader": "^1.3.3",
        "license-report": "^6.8.2",
        "license-report-check": "^1.0.0",
        "license-report-recursive": "^6.8.4",
        "npm-check-updates": "^21.0.3",
        "owasp-dependency-check": "^1.0.1",
        "prettier": "^3.8.3",
        "rollup-plugin-visualizer": "^7.0.1",
        "sonda": "^0.11.1",
        "typescript": "^5.9.3",
        "vite": "^8.0.9",
        "vite-plugin-dts": "^4.5.4",
        "vite-plugin-wasm": "^3.6.0",
        "vitest": "^4.1.5"
    },
    "scripts": {
        "build": "npm run build:wasm && npx vite build",
        "check": "node -e \"import('@dpuse/dpuse-development').then(m => m.checkDependencies())\"",
        "build:wasm": "wasm-pack build rust/dpuse_tool_rust_csv_core --target web --release",
        "format": "node -e \"import('@dpuse/dpuse-development').then(m => m.formatCode())\"",
        "lint": "node -e \"import('@dpuse/dpuse-development').then(m => m.lintCode())\"",
        "release": "op run --env-file=.env -- node -e \"import('@dpuse/dpuse-development').then(m => m.releaseProject())\"",
        "sync": "node -e \"import('@dpuse/dpuse-development').then(m => m.syncProjectWithGitHub())\""
    }
}